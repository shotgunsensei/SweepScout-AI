{
  "manifest_version": 3,
  "name": "SweepScout Companion",
  "short_name": "SweepScout",
  "version": "0.1.0",
  "description": "Detect sweepstakes pages, show eligibility/risk overlays, save to SweepScout, and prefill only approved profile fields.",
  "action": {
    "default_title": "SweepScout",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "http://*/*",
    "https://*/*"
  ]
}
