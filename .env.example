# Runtime
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
APP_BASE_URL=http://localhost:5173
API_PROXY_TARGET=http://127.0.0.1:5000
LOCAL_SQLITE_PATH=.data/playpackpilot.sqlite
TRUST_PROXY=false

# Production PostgreSQL / Supabase (required for production)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_GOOGLE_OAUTH_ENABLED=false

# Platform ownership and local development
PLATFORM_OWNER_EMAIL=john@shotgunninjas.com
PLAYPACKPILOT_LOCAL_ADMIN=false
PLAYPACKPILOT_DEFAULT_ORG_NAME=Personal Hangar
PLAYPACKPILOT_DEFAULT_ORG_SLUG=personal-hangar

# OpenAI (use either the standard key or Replit integration variables)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=

# Approved discovery provider
SEARCH_PROVIDER=mock
SEARCH_PROVIDER_ENDPOINT=
SEARCH_PROVIDER_API_KEY=
BROWSER_HEADLESS=true
SCANNER_USER_AGENT=PlayPackPilotBot/1.0 (+https://playpackpilot.com/source-policy)
PLAYPACKPILOT_SCANNER_ENABLED=false

# Review-only inbox monitoring. The service must never open links automatically.
PLAYPACKPILOT_INBOX_ENABLED=false
PLAYPACKPILOT_INBOX_PROVIDER=gmail
PLAYPACKPILOT_INBOX_EMAIL=
PLAYPACKPILOT_IMAP_USER=
PLAYPACKPILOT_IMAP_PASSWORD=
PLAYPACKPILOT_IMAP_HOST=imap.gmail.com
PLAYPACKPILOT_IMAP_PORT=993
PLAYPACKPILOT_IMAP_TLS=true
PLAYPACKPILOT_INBOX_MAILBOX=INBOX
PLAYPACKPILOT_INBOX_MAX_MESSAGES=25
PLAYPACKPILOT_INBOX_LOOKBACK_DAYS=14

# Stripe test mode. Do not insert live keys in this file.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_COPILOT_MONTHLY=
STRIPE_PRICE_COPILOT_ANNUAL=
STRIPE_PRICE_ACE_PILOT_MONTHLY=
STRIPE_PRICE_ACE_PILOT_ANNUAL=
STRIPE_PRICE_SQUADRON_MONTHLY=
STRIPE_PRICE_SQUADRON_ANNUAL=
BILLING_GRACE_PERIOD_DAYS=3

# Pilot Credit operation costs. Server-authoritative internal usage units only.
PILOT_CREDIT_COST_BASIC_ELIGIBILITY=1
PILOT_CREDIT_COST_PERSONALIZED_FIT=1
PILOT_CREDIT_COST_RULES_SUMMARY=2
PILOT_CREDIT_COST_ENTRY_CHECKLIST=2
PILOT_CREDIT_COST_DEEP_LEGITIMACY=3
PILOT_CREDIT_COST_OFFICIAL_RULES_EXTRACTION=3
PILOT_CREDIT_COST_PROMOTION_DEEP_ANALYSIS=3
PILOT_CREDIT_COST_PERSONALIZED_REPORT=5
PILOT_CREDIT_COST_CUSTOM_SCAN=10
PILOT_CREDIT_COST_LARGE_SOURCE_SCAN=20

# Reserved for the durable job and email phases; not consumed by the current app.
JOB_QUEUE_DATABASE_URL=
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=

# Legacy SweepScout compatibility during migration only. Remove after the
# corresponding code has moved to PLAYPACKPILOT_* names.
SWEEPSCOUT_ORGANIZATION_ID=
SWEEPSCOUT_USER_ID=
SWEEPSCOUT_OWNER_EMAIL=
SWEEPSCOUT_ADMIN_EMAILS=
SWEEPSCOUT_ADMIN_USER_IDS=
SWEEPSCOUT_LOCAL_ADMIN=false
SWEEPSCOUT_PLAN_TIER=
SWEEPSCOUT_DEFAULT_ORG_NAME=
SWEEPSCOUT_DEFAULT_ORG_SLUG=
SWEEPSCOUT_INBOX_ENABLED=false
SWEEPSCOUT_INBOX_PROVIDER=gmail
SWEEPSCOUT_INBOX_EMAIL=
SWEEPSCOUT_IMAP_USER=
SWEEPSCOUT_IMAP_PASSWORD=
SWEEPSCOUT_IMAP_HOST=imap.gmail.com
SWEEPSCOUT_IMAP_PORT=993
SWEEPSCOUT_IMAP_TLS=true
SWEEPSCOUT_INBOX_MAILBOX=INBOX
SWEEPSCOUT_INBOX_MAX_MESSAGES=25
SWEEPSCOUT_INBOX_LOOKBACK_DAYS=14
STRIPE_PRICE_PRO=
STRIPE_PRICE_POWER=
